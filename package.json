{
  "name": "puppy-life-os",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "admin:dev": "pnpm --filter admin dev",
    "admin:build": "pnpm --filter admin build",
    "admin:preview": "pnpm --filter admin preview",
    "gen:openapi": "cargo run -p api -- --export-openapi packages/admin/openapi.json",
    "gen:api": "pnpm run gen:openapi && pnpm --filter admin gen:api"
  },
  "packageManager": "pnpm@10.33.0"
}
